# =============================================================================
# MockBank Passwordless POC — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# IBM Verify SaaS — Tenant
# -----------------------------------------------------------------------------

# Base URL of your IBM Verify SaaS tenant.
# Format: https://<your-tenant-id>.verify.ibm.com
VERIFY_TENANT_URL=https://yourtenantid.verify.ibm.com

# Client ID of the OIDC application registered in IBM Verify admin console.
# Found under: Applications → <your app> → General → Client ID
VERIFY_CLIENT_ID=your-client-id-here

# Client secret of the OIDC application.
# Found under: Applications → <your app> → General → Client Secret
# Treat this like a password — never log or expose it.
VERIFY_CLIENT_SECRET=your-client-secret-here

# OIDC issuer URL — obtained from the OIDC discovery endpoint's "issuer" field.
# Typically: https://<your-tenant-id>.verify.ibm.com/oidc/endpoint/default
VERIFY_OIDC_ISSUER=https://yourtenantid.verify.ibm.com/oidc/endpoint/default

# -----------------------------------------------------------------------------
# WebAuthn / FIDO2
# -----------------------------------------------------------------------------

# Relying Party ID — must exactly match the ngrok public domain (no protocol, no trailing slash).
# Example: abcd1234.ngrok-free.app
FIDO2_RP_ID=your-ngrok-subdomain.ngrok-free.app

# Relying Party Origin — full HTTPS origin matching the ngrok domain above.
# Example: https://abcd1234.ngrok-free.app
FIDO2_RP_ORIGIN=https://your-ngrok-subdomain.ngrok-free.app

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------

# Secret key used to sign session JWTs (HS256).
# Must be at least 32 characters of random data.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-minimum-32-character-random-secret-value

# -----------------------------------------------------------------------------
# ngrok Tunnel
# -----------------------------------------------------------------------------

# Authentication token from your ngrok account (https://dashboard.ngrok.com/get-started/your-authtoken).
# Required to start the HTTPS tunnel that WebAuthn relies on.
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
